{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "extends": ["./tooling/biome/biome.json"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/dist",
      "!**/.astro",
      "!**/*.astro",
      "!**/routeTree.gen.ts",
      "!**/migrations"
    ]
  }
}
