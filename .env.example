# ── Server (packages/env/src/server.ts) ─────────────────────────────
NODE_ENV=development
PORT=3000
WEB_URL=http://localhost:5173

# Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hard_stack

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Hard Stack <onboarding@resend.dev>

# ── Client (packages/env/src/client.ts) — VITE_ prefixed only ────────
VITE_SERVER_URL=http://localhost:3000
