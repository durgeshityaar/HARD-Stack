{
  "name": "hard-stack",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "turbo run generate -F @hard-stack/db",
    "db:migrate": "turbo run migrate -F @hard-stack/db",
    "db:push": "turbo run push -F @hard-stack/db",
    "db:studio": "turbo run studio -F @hard-stack/db",
    "clean": "turbo run clean",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@hard-stack/biome-config": "workspace:*",
    "@hard-stack/tsconfig": "workspace:*",
    "@types/node": "26.0.1",
    "lefthook": "2.1.9",
    "turbo": "2.10.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
